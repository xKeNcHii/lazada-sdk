{
  "name": "@lazada-sdk/sdk",
  "version": "0.0.1",
  "description": "Unofficial TypeScript SDK for the Lazada Open Platform API. Not affiliated with Lazada.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE"],
  "keywords": [
    "lazada",
    "api",
    "sdk",
    "typescript",
    "e-commerce",
    "southeast-asia",
    "marketplace",
    "openapi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xKeNcHii/lazada-sdk.git",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/xKeNcHii/lazada-sdk#readme",
  "bugs": {
    "url": "https://github.com/xKeNcHii/lazada-sdk/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit",
    "typecheck": "tsc --noEmit",
    "gen:types": "openapi-typescript ../../spec/openapi/lazada.openapi.yaml -o src/schemas/generated.ts",
    "prepublishOnly": "pnpm gen:types && pnpm build"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "msw": "^2.7.0",
    "openapi-typescript": "^7.4.4",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@vitest/coverage-v8": "^4.1.4",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "size-limit": [
    {
      "name": "ESM full bundle",
      "path": "dist/index.js",
      "limit": "100 KB",
      "gzip": true,
      "ignore": ["crypto", "node:crypto"]
    },
    {
      "name": "Signing + errors only (no managers, tree-shaken)",
      "path": "dist/index.js",
      "import": "{ signRequest, LazadaApiError }",
      "limit": "5 KB",
      "gzip": true,
      "ignore": ["crypto", "node:crypto"]
    },
    {
      "name": "SDK + Order + Seller managers (tree-shaken)",
      "path": "dist/index.js",
      "import": "{ LazadaSDK, OrderManager, SellerManager }",
      "limit": "40 KB",
      "gzip": true,
      "ignore": ["crypto", "node:crypto"]
    }
  ]
}
