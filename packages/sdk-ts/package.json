{
  "name": "@lazada-sdk/sdk",
  "version": "0.0.1",
  "description": "Unofficial TypeScript SDK for the Lazada Open Platform API. Not affiliated with Lazada.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE"],
  "keywords": [
    "lazada",
    "api",
    "sdk",
    "typescript",
    "e-commerce",
    "southeast-asia",
    "marketplace",
    "openapi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xKeNcHii/lazada-sdk.git",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/xKeNcHii/lazada-sdk#readme",
  "bugs": {
    "url": "https://github.com/xKeNcHii/lazada-sdk/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "gen:types": "openapi-typescript ../../spec/openapi/lazada.openapi.yaml -o src/schemas/generated.ts",
    "prepublishOnly": "pnpm gen:types && pnpm build"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "msw": "^2.7.0",
    "openapi-typescript": "^7.4.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
