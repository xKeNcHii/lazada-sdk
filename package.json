{
  "name": "lazada-sdk-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "docs:rebuild": "cd scraper && ./venv/bin/python scrape.py && cd .. && pnpm --filter @lazada-sdk/spec build",
    "spec:build": "pnpm --filter @lazada-sdk/spec build",
    "spec:lint": "pnpm --filter @lazada-sdk/spec lint"
  }
}
