{
  "name": "@lazada-sdk/spec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/parse-docs.js",
  "bin": {
    "lazada-parse-docs": "./dist/parse-docs.js"
  },
  "scripts": {
    "build": "tsc && node dist/parse-docs.js",
    "parse": "tsx src/parse-docs.ts",
    "bootstrap:managers": "tsx src/bootstrap-managers.ts",
    "lint": "redocly lint openapi/lazada.openapi.yaml",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.29.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  }
}
