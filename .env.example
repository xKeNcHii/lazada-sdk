# Copy to .env and fill in. Required for running examples/*.ts against the
# live Lazada Open Platform. Obtain credentials from https://open.lazada.com/.
# .env is gitignored — secrets stay local.

# ─────────────────────────────────────────────────────────────────────
# App credentials (always required). From the Lazada developer console.
# ─────────────────────────────────────────────────────────────────────
LAZADA_APP_KEY=
LAZADA_APP_SECRET=

# Marketplace region the seller belongs to. One of: SG | VN | PH | MY | TH | ID.
LAZADA_REGION=SG

# ─────────────────────────────────────────────────────────────────────
# Auth — pick ONE of the three flows below. Delete the other two.
# ─────────────────────────────────────────────────────────────────────

# (1) You already have a live access token (simplest):
LAZADA_ACCESS_TOKEN=
# Optional — if set, the SDK auto-refreshes the access token before expiry.
# LAZADA_REFRESH_TOKEN=
# Optional — unix seconds. If omitted, the SDK refreshes lazily on 401.
# LAZADA_TOKEN_EXPIRES_AT=

# (2) You have a one-time OAuth `code` from the authorize redirect and want
#     the SDK to exchange it. Uncomment and fill, leave ACCESS_TOKEN empty:
# LAZADA_OAUTH_CODE=

# (3) You only have a refresh token (long-lived). Uncomment and fill:
# LAZADA_REFRESH_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────
# Override the auth host (default: https://auth.lazada.com/rest).
# Useful if your app is on a non-lazada.com partner host.
# LAZADA_AUTH_BASE_URL=
