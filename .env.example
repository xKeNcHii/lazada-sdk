# Copy to .env and fill in. Required for running examples/*.ts against the
# live Lazada Open Platform. Obtain credentials from https://open.lazada.com/.

# App credentials from the Lazada developer console.
LAZADA_APP_KEY=
LAZADA_APP_SECRET=

# Seller OAuth access token. Exchange an OAuth `code` via
# sdk.system.createAuthToken({ code }) to obtain these.
LAZADA_ACCESS_TOKEN=
# LAZADA_REFRESH_TOKEN=        # optional — enables auto-refresh

# Marketplace region. One of: SG | VN | PH | MY | TH | ID.
LAZADA_REGION=SG
